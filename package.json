{
  "name": "easyploy",
  "version": "0.1.0",
  "private": true,
  "description": "Declarative deployment engine for self-hosted infrastructure",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean --force && rm -rf node_modules",
    "prepare": "husky install"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "~5.6.0",
    "husky": "^9.0.0"
  },
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=20"
  }
}
